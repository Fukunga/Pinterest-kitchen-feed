# Gemini API Key (Generate from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# WordPress Credentials
WP_URL=https://your-wordpress-domain.com
WP_USERNAME=your_wp_username
WP_APPLICATION_PASSWORD=xxxx_xxxx_xxxx_xxxx_xxxx

# Amazon US Associate Tag
AMAZON_ASSOCIATE_TAG=your_us_tag_20

# Amazon JP Associate Tag (For future expansion)
AMAZON_ASSOCIATE_TAG_JP=your_jp_tag_22
